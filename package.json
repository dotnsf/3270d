    "dotenv": "^16.3.1"
  },
  "optionalDependencies": {
    "authenticate-pam": "^1.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.0.2",
    "eslint": "^8.56.0",
    "@types/jest": "^29.5.11"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}